import cv2
import numpy as np

"""global variables"""
color = 100                  # initial H value (hue)
lo = np.array([color - 5, 100, 50])
hi = np.array([color + 5, 255, 255])
color_info = (0, 255, 255)   # display color (BGR)
image = None                 # used in the loop (initial value)

def mouse(event, x, y, flags, param):
    """detects mouse actions"""
    
    global lo, hi, color, image
    # Left click: pick the pixel color (hue)
    if event == cv2.EVENT_LBUTTONDOWN and image is not None:
        color = int(image[y, x][0])
    # Scroll wheel: increase/decrease hue value
    if event == cv2.EVENT_MOUSEWHEEL:
        if flags < 0:        # scroll down
            if color > 5:
                color -= 1
        else:                # scroll up
            if color < 250:
                color += 1
    # Update HSV bounds
    lo[:] = [color - 5, 100, 50]
    hi[:] = [color + 5, 255, 255]

"""video capture initialization"""
cap = cv2.VideoCapture(0)    # 0 or 1 depending on the PC
cv2.namedWindow("Camera")
cv2.setMouseCallback("Camera", mouse)

while True:
    ret, frame = cap.read()
    if not ret:
        break

    """image processing"""
    
    # BGR -> HSV conversion
    image = cv2.cvtColor(frame, cv2.COLOR_BGR2HSV)
    image = cv2.blur(image, (5, 5))
    # Color mask
    mask = cv2.inRange(image, lo, hi)
    mask = cv2.erode(mask, None, iterations=1)
    mask = cv2.dilate(mask, None, iterations=1)
    # Filtered image (black & white)
    image2 = cv2.bitwise_and(frame, frame, mask=mask)

    """object detection"""
    
    elements = cv2.findContours(mask, cv2.RETR_EXTERNAL,
                                cv2.CHAIN_APPROX_SIMPLE)[-2]
    if len(elements) > 0:
        c = max(elements, key=cv2.contourArea)
        ((x, y), radius) = cv2.minEnclosingCircle(c)
        if radius > 30:  # filter out noise (prevents detecting small artifacts)
            # circle around the object
            cv2.circle(image2, (int(x), int(y)), int(radius), color_info, 2)
            
            # small dot at the center of the object
            cv2.circle(frame, (int(x), int(y)), 5, color_info, 10)
            
            # horizontal line pointing to the object
            cv2.line(frame, (int(x), int(y)),
                     (int(x) + 150, int(y)), color_info, 2)
            
            # text annotation on the object
            cv2.putText(frame, "Objet",
                        (int(x) + 10, int(y) - 10),
                        cv2.FONT_HERSHEY_DUPLEX, 1,
                        color_info, 1, cv2.LINE_AA)

    # Display current hue value
    cv2.putText(frame, "Couleur : {}".format(color),
                (10, 30), cv2.FONT_HERSHEY_DUPLEX,
                1, color_info, 1, cv2.LINE_AA)

    """display both masks (bitwise and color) and the camera feed"""
    
    cv2.imshow("Camera", frame)
    cv2.imshow("Image2", image2)
    cv2.imshow("Mask", mask)
    # exit on 'q' key press
    if cv2.waitKey(1) == ord('q'):
        break

# release the camera and close all 3 windows
cap.release()
cv2.destroyAllWindows()
